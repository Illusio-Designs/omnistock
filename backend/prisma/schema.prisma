// OmniStock - EasyEcom-like ERP (Multi-tenant SaaS)
// Database: MySQL | ORM: Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// SAAS: TENANTS, PLANS, SUBSCRIPTIONS
// ─────────────────────────────────────────

model Tenant {
  id            String   @id @default(uuid())
  slug          String   @unique
  businessName  String
  legalName     String?
  ownerEmail    String
  ownerName     String?
  phone         String?
  gstin         String?
  country       String?  @default("IN")
  industry      String?
  companySize   String?
  website       String?
  logo          String?  @db.Text
  status        TenantStatus @default(TRIAL)
  trialEndsAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users           User[]
  roles           TenantRole[]
  subscription    Subscription?
  usageMeters     UsageMeter[]
  invoicesBilling BillingInvoice[]

  products        Product[]
  variants        ProductVariant[]
  categories      Category[]
  brands          Brand[]
  warehouses      Warehouse[]
  inventoryItems  InventoryItem[]
  stockMovements  StockMovement[]
  channels        Channel[]
  channelListings ChannelListing[]
  channelRequests ChannelRequest[]
  vendors         Vendor[]
  customers       Customer[]
  orders          Order[]
  orderItems      OrderItem[]
  purchaseOrders  PurchaseOrder[]
  purchaseItems   PurchaseOrderItem[]
  returns         Return[]
  invoices        Invoice[]
  payments        Payment[]
  shipments       Shipment[]

  @@map("tenants")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

model Plan {
  id            String   @id @default(uuid())
  code          String   @unique  // STANDARD | PROFESSIONAL | ENTERPRISE | CUSTOM
  name          String
  tagline       String?  @db.Text
  description   String?  @db.Text
  monthlyPrice  Decimal  @db.Decimal(10, 2) @default(0)
  yearlyPrice   Decimal  @db.Decimal(10, 2) @default(0)
  currency      String   @default("INR")
  isPublic      Boolean  @default(true)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)

  // Hard limits (null = unlimited)
  maxFacilities Int?
  maxSkus       Int?
  maxUserRoles  Int?
  maxUsers      Int?
  maxOrdersPerMonth Int?

  // Feature flags (boolean) — drive UI gating + middleware
  features      Json     @default("{}")
  // PAYG metered overage rates
  meteredRates  Json     @default("{}")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId          String
  plan            Plan     @relation(fields: [planId], references: [id])
  billingCycle    BillingCycle @default(MONTHLY)
  status          SubscriptionStatus @default(TRIALING)
  startedAt       DateTime @default(now())
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime
  trialEndsAt     DateTime?
  cancelAt        DateTime?
  cancelledAt     DateTime?
  // PAYG flag — when true, overage usage is billed monthly
  payAsYouGo      Boolean  @default(false)
  // External payment provider refs (Razorpay/Stripe placeholders)
  provider        String?
  providerCustomerId String?
  providerSubscriptionId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices        BillingInvoice[]

  @@map("subscriptions")
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model UsageMeter {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metric      String   // e.g. "orders", "skus", "warehouses", "api_calls"
  period      String   // e.g. "2026-04"
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, metric, period])
  @@index([tenantId, metric])
  @@map("usage_meters")
}

model BillingInvoice {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  invoiceNumber   String   @unique
  periodStart     DateTime
  periodEnd       DateTime
  baseAmount      Decimal  @db.Decimal(12, 2) @default(0)
  overageAmount   Decimal  @db.Decimal(12, 2) @default(0)
  taxAmount       Decimal  @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal  @db.Decimal(12, 2)
  currency        String   @default("INR")
  status          BillingInvoiceStatus @default(DUE)
  paidAt          DateTime?
  providerRef     String?
  lineItems       Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("billing_invoices")
}

enum BillingInvoiceStatus {
  DRAFT
  DUE
  PAID
  FAILED
  VOID
}

// ─────────────────────────────────────────
// RBAC: PERMISSIONS, ROLES (per-tenant)
// ─────────────────────────────────────────

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique  // e.g. "products.create", "orders.read", "billing.manage"
  module      String              // products, orders, inventory, billing, admin, etc.
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model TenantRole {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String   // e.g. "Warehouse Manager"
  code        String   // e.g. "WAREHOUSE_MANAGER"
  description String?
  isSystem    Boolean  @default(false) // built-in templates: ADMIN, MANAGER, STAFF, ACCOUNTANT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, code])
  @@map("tenant_roles")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  role         TenantRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId  String
  role    TenantRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?
  name         String
  avatar       String?  @db.Text
  provider     AuthProvider @default(LOCAL)
  providerId   String?
  // Coarse legacy role kept for back-compat. New code should use UserRole.
  role         Role     @default(STAFF)
  // Platform-level super admin (SaaS founder/staff). Bypasses tenant scoping.
  isPlatformAdmin Boolean @default(false)
  // Tenant the user belongs to. Null = platform admin not yet attached.
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  isActive     Boolean  @default(true)
  emailVerified Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles            UserRole[]
  orders           Order[]
  purchaseOrders   PurchaseOrder[]
  channelRequests  ChannelRequest[]

  @@index([provider, providerId])
  @@index([tenantId])
  @@map("users")
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  ACCOUNTANT
}

// ─────────────────────────────────────────
// CMS: BLOG + SEO (managed by platform admin)
// ─────────────────────────────────────────

model BlogPost {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  excerpt     String?  @db.Text
  content     String   @db.LongText
  coverImage  String?  @db.Text
  authorName  String?
  tags        Json     @default("[]")
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?
  // SEO
  metaTitle       String?
  metaDescription String?  @db.Text
  metaKeywords    String?  @db.Text
  ogImage         String?  @db.Text
  canonicalUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, publishedAt])
  @@map("blog_posts")
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─────────────────────────────────────────
// PLATFORM SETTINGS  (key/value, admin-managed)
// Secrets are AES-256-GCM encrypted in `value`.
// ─────────────────────────────────────────

model PlatformSetting {
  id          String   @id @default(uuid())
  key         String   @unique          // e.g. "amazon.clientId", "razorpay.keyId"
  value       String?  @db.Text         // encrypted JSON if isSecret, raw text otherwise
  category    String                    // "amazon", "razorpay", "smtp", "shopify", etc.
  label       String?                   // human display name
  description String?  @db.Text
  isSecret    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([category])
  @@map("platform_settings")
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String?
  userId      String?
  userEmail   String?
  action      String   // e.g. "product.create", "billing.change_plan"
  resource    String?  // e.g. "product", "order"
  resourceId  String?
  ip          String?
  userAgent   String?  @db.Text
  method      String?
  path        String?  @db.Text
  statusCode  Int?
  metadata    Json?    // extra context (diff, reason, etc.)
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// PUBLIC CONTENT (CMS for marketing pages)
// Single table discriminated by `type` — handles features,
// solutions, about, help, resources, FAQs, case studies, videos, etc.
// Structured extras go in `data` JSON so we can add fields per type
// without migrations.
// ─────────────────────────────────────────

model PublicContent {
  id          String   @id @default(uuid())
  type        ContentType
  slug        String?  @unique
  title       String
  subtitle    String?  @db.Text
  body        String?  @db.LongText
  image       String?  @db.Text
  icon        String?  // lucide icon name, e.g. "Sparkles"
  category    String?  // grouping within a type (e.g. "ECOM", "GENERAL")
  href        String?  // click-through URL for card types
  sortOrder   Int      @default(0)
  data        Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, isActive, sortOrder])
  @@map("public_content")
}

enum ContentType {
  LANDING_CHALLENGE
  LANDING_FEATURE_TOOL
  LANDING_FAQ
  FEATURE
  SOLUTION
  ABOUT_SECTION
  ABOUT_VALUE
  ABOUT_TIMELINE
  HELP_CATEGORY
  HELP_FAQ
  RESOURCE_TILE
  VIDEO
  CASE_STUDY
}

model SeoSetting {
  id              String   @id @default(uuid())
  path            String   @unique  // e.g. "/", "/pricing", "/features"
  title           String
  description     String?  @db.Text
  keywords        String?  @db.Text
  ogTitle         String?
  ogDescription   String?  @db.Text
  ogImage         String?  @db.Text
  twitterCard     String?
  canonicalUrl    String?
  robots          String?  @default("index,follow")
  schemaJsonLd    String?  @db.LongText
  updatedAt       DateTime @updatedAt

  @@map("seo_settings")
}

// ─────────────────────────────────────────
// CHANNEL REQUESTS
// ─────────────────────────────────────────

model ChannelRequest {
  id          String               @id @default(uuid())
  tenantId    String
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        String
  category    ChannelCategory      @default(CUSTOM)
  name        String?
  notes       String?              @db.Text
  requestedBy String
  user        User                 @relation(fields: [requestedBy], references: [id])
  status      ChannelRequestStatus @default(PENDING)
  adminNotes  String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([tenantId])
  @@map("channel_requests")
}

enum ChannelRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// ─────────────────────────────────────────
// CHANNELS (Marketplaces / Stores)
// ─────────────────────────────────────────

model Channel {
  id            String          @id @default(uuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  type          ChannelType
  category      ChannelCategory @default(ECOM)
  credentials   Json?
  isActive      Boolean         @default(true)
  lastSyncAt    DateTime?
  syncError     String?         @db.Text
  webhookSecret String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  orders      Order[]
  listings    ChannelListing[]

  @@index([tenantId])
  @@map("channels")
}

enum ChannelCategory {
  ECOM
  QUICKCOM
  LOGISTICS
  OWNSTORE
  SOCIAL
  B2B
  CUSTOM
}

enum ChannelType {
  AMAZON
  FLIPKART
  MYNTRA
  MEESHO
  SNAPDEAL
  PAYTM_MALL
  NYKAA
  AJIO
  TATA_CLIQ
  GLOWROAD
  JIOMART
  LIMEROAD
  EBAY
  ETSY
  BLINKIT
  ZEPTO
  SWIGGY_INSTAMART
  BB_NOW
  AMAZON_SMARTBIZ
  SHOPIFY
  WOOCOMMERCE
  MAGENTO
  BIGCOMMERCE
  OPENCART
  WEBSITE
  OFFLINE
  POS
  SHIPROCKET
  DELHIVERY
  FSHIP
  BLUEDART
  DTDC
  ECOMEXPRESS
  XPRESSBEES
  SHADOWFAX
  FEDEX
  DHL
  UPS
  ITHINK
  PICKRR
  SHIPWAY
  NIMBUSPOST
  CLICKPOST
  INSTAGRAM
  FACEBOOK
  WHATSAPP_BUSINESS
  B2B_PORTAL
  WHOLESALE
  DISTRIBUTOR
  CUSTOM_WEBHOOK
  OTHER
}

// ─────────────────────────────────────────
// PRODUCTS & INVENTORY
// ─────────────────────────────────────────

model Category {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  parentId  String?
  parent    Category? @relation("CategoryChildren", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryChildren")
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

model Brand {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("brands")
}

model Product {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  sku          String
  barcode      String?
  description  String?  @db.Text
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  brandId      String?
  brand        Brand?   @relation(fields: [brandId], references: [id])
  weight       Float?
  dimensions   Json?
  images       Json     @default("[]")
  tags         Json     @default("[]")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  variants         ProductVariant[]
  channelListings  ChannelListing[]
  inventoryItems   InventoryItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

model ProductVariant {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String
  barcode     String?
  name        String
  attributes  Json
  costPrice   Decimal  @db.Decimal(10, 2)
  mrp         Decimal  @db.Decimal(10, 2)
  sellingPrice Decimal @db.Decimal(10, 2)
  weight      Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventoryItems   InventoryItem[]
  orderItems       OrderItem[]
  purchaseItems    PurchaseOrderItem[]
  channelListings  ChannelListing[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("product_variants")
}

model ChannelListing {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channelId     String
  channel       Channel        @relation(fields: [channelId], references: [id])
  productId     String
  product       Product        @relation(fields: [productId], references: [id])
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  channelSku    String
  channelPrice  Decimal        @db.Decimal(10, 2)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([channelId, channelSku])
  @@index([tenantId])
  @@map("channel_listings")
}

// ─────────────────────────────────────────
// WAREHOUSES & INVENTORY
// ─────────────────────────────────────────

model Warehouse {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  address     Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventoryItems InventoryItem[]
  stockMovements StockMovement[]
  ordersFrom     Order[]  @relation("OrderWarehouse")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("warehouses")
}

model InventoryItem {
  id              String         @id @default(uuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse      @relation(fields: [warehouseId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  quantityOnHand  Int            @default(0)
  quantityReserved Int           @default(0)
  quantityAvailable Int          @default(0)
  reorderPoint    Int            @default(0)
  reorderQty      Int            @default(0)
  location        String?
  updatedAt       DateTime       @updatedAt

  @@unique([warehouseId, variantId])
  @@index([tenantId])
  @@map("inventory_items")
}

model StockMovement {
  id            String        @id @default(uuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouseId   String
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])
  variantId     String
  type          MovementType
  quantity      Int
  referenceId   String?
  referenceType String?
  notes         String?
  createdAt     DateTime      @default(now())

  @@index([tenantId])
  @@map("stock_movements")
}

enum MovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  TRANSFER
  RETURN
}

// ─────────────────────────────────────────
// VENDORS
// ─────────────────────────────────────────

model Vendor {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String?
  gstin        String?
  address      Json?
  bankDetails  Json?
  paymentTerms String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@map("vendors")
}

// ─────────────────────────────────────────
// PURCHASE ORDERS (Inward)
// ─────────────────────────────────────────

model PurchaseOrder {
  id            String              @id @default(uuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  poNumber      String
  vendorId      String
  vendor        Vendor              @relation(fields: [vendorId], references: [id])
  status        PurchaseOrderStatus @default(DRAFT)
  expectedDate  DateTime?
  receivedDate  DateTime?
  totalAmount   Decimal             @db.Decimal(12, 2) @default(0)
  notes         String?             @db.Text
  createdById   String
  createdBy     User                @relation(fields: [createdById], references: [id])
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  items     PurchaseOrderItem[]
  invoices  Invoice[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  orderedQty      Int
  receivedQty     Int           @default(0)
  unitCost        Decimal       @db.Decimal(10, 2)
  totalCost       Decimal       @db.Decimal(12, 2)

  @@index([tenantId])
  @@map("purchase_order_items")
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

// ─────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  address   Json?
  isB2B     Boolean  @default(false)
  gstIn     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders  Order[]

  @@index([tenantId])
  @@map("customers")
}

model Order {
  id              String      @id @default(uuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderNumber     String
  channelId       String
  channel         Channel     @relation(fields: [channelId], references: [id])
  channelOrderId  String?
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  warehouseId     String?
  warehouse       Warehouse?  @relation("OrderWarehouse", fields: [warehouseId], references: [id])
  status          OrderStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   String?
  shippingAddress Json
  billingAddress  Json?
  subtotal        Decimal     @db.Decimal(12, 2)
  discount        Decimal     @db.Decimal(10, 2) @default(0)
  shippingCharge  Decimal     @db.Decimal(10, 2) @default(0)
  tax             Decimal     @db.Decimal(10, 2) @default(0)
  total           Decimal     @db.Decimal(12, 2)
  notes           String?     @db.Text
  trackingNumber  String?
  courierName     String?
  createdById     String?
  createdBy       User?       @relation(fields: [createdById], references: [id])
  orderedAt          DateTime    @default(now())
  shippedAt          DateTime?
  deliveredAt        DateTime?
  reviewRequestedAt  DateTime?
  reviewRequestError String?     @db.Text
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  items     OrderItem[]
  invoices  Invoice[]
  returns   Return[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@map("orders")
}

model OrderItem {
  id         String         @id @default(uuid())
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  qty        Int
  unitPrice  Decimal        @db.Decimal(10, 2)
  discount   Decimal        @db.Decimal(10, 2) @default(0)
  tax        Decimal        @db.Decimal(10, 2) @default(0)
  total      Decimal        @db.Decimal(12, 2)

  @@index([tenantId])
  @@map("order_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
  FAILED
}

// ─────────────────────────────────────────
// RETURNS
// ─────────────────────────────────────────

model Return {
  id        String       @id @default(uuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id])
  reason    String       @db.Text
  status    ReturnStatus @default(REQUESTED)
  refundAmt Decimal?     @db.Decimal(10, 2)
  notes     String?      @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([tenantId])
  @@map("returns")
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  RECEIVED
  REFUNDED
  REJECTED
}

// ─────────────────────────────────────────
// INVOICES & RECONCILIATION
// ─────────────────────────────────────────

model Invoice {
  id              String          @id @default(uuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceNumber   String
  type            InvoiceType
  orderId         String?
  order           Order?          @relation(fields: [orderId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  amount          Decimal         @db.Decimal(12, 2)
  tax             Decimal         @db.Decimal(10, 2) @default(0)
  total           Decimal         @db.Decimal(12, 2)
  status          InvoiceStatus   @default(UNPAID)
  dueDate         DateTime?
  paidAt          DateTime?
  notes           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  payments Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@map("invoices")
}

model Payment {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id])
  amount      Decimal       @db.Decimal(12, 2)
  method      String
  reference   String?
  paidAt      DateTime      @default(now())
  notes       String?

  @@index([tenantId])
  @@map("payments")
}

enum InvoiceType {
  SALE
  PURCHASE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

// ─────────────────────────────────────────
// SHIPMENTS & LOGISTICS
// ─────────────────────────────────────────

model Shipment {
  id             String         @id @default(uuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderNumber    String
  courierName    String
  trackingNumber String?
  status         ShipmentStatus @default(PENDING)
  weight         Float?
  charges        Decimal?       @db.Decimal(10, 2)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId])
  @@map("shipments")
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}
