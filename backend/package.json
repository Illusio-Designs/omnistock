{
  "name": "omnistock-backend",
  "version": "1.0.0",
  "description": "OmniStock ERP Backend - Node.js + Express + Prisma",
  "main": "src/index.js",
  "scripts": {
    "dev": "prisma generate && nodemon src/index.js",
    "start": "prisma generate && node src/index.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js && node prisma/seed-content.js",
    "db:seed-content": "node prisma/seed-content.js",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "billing:run": "node src/jobs/billing.job.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^9.11.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
