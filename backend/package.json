{
  "name": "kartriq-backend",
  "version": "1.0.0",
  "description": "Kartriq ERP Backend - Node.js + Express + Knex + MySQL",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon --exec \"node --disable-warning=DEP0040\" src/index.js",
    "start": "node --disable-warning=DEP0040 src/index.js",
    "billing:run": "node --disable-warning=DEP0040 src/jobs/billing.job.js",
    "cron:run": "node --disable-warning=DEP0040 src/jobs/cron.job.js",
    "seed": "node --disable-warning=DEP0040 src/scripts/seed.js",
    "test:backend": "node --disable-warning=DEP0040 src/scripts/test.js",
    "test:backend:server": "DISABLE_RATE_LIMIT=true node --disable-warning=DEP0040 src/index.js"
  },
  "dependencies": {
    "@sentry/node": "^8.40.0",
    "axios": "^1.7.0",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.0",
    "google-auth-library": "^9.11.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.2.9",
    "morgan": "^1.10.0",
    "mysql2": "^3.22.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "razorpay": "^2.9.4",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
