{
  "expo": {
    "name": "Kartriq",
    "slug": "kartriq",
    "scheme": "kartriq",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kartriq.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock your Kartriq workspace.",
        "NSUserNotificationsUsageDescription": "Get alerted when new orders arrive, payments fail, or stock runs low.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:kartriq.com",
        "applinks:www.kartriq.com",
        "applinks:app.kartriq.com"
      ]
    },
    "android": {
      "package": "com.kartriq.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06D4B8"
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "POST_NOTIFICATIONS",
        "INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "kartriq.com", "pathPrefix": "/m" },
            { "scheme": "https", "host": "www.kartriq.com", "pathPrefix": "/m" },
            { "scheme": "https", "host": "app.kartriq.com" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#06D4B8",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://api.kartriq.com/api/v1",
      "googleIosClientId":     "TODO_GOOGLE_IOS_CLIENT_ID",
      "googleAndroidClientId": "TODO_GOOGLE_ANDROID_CLIENT_ID",
      "googleWebClientId":     "TODO_GOOGLE_WEB_CLIENT_ID"
    }
  }
}
