  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:big": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096 --max-semi-space-size=64\" next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build",
    "typecheck": "tsc --noEmit",
