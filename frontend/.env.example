# ── Required ─────────────────────────────────────────────────────────────────
# Backend API base URL. Must include the /api/v1 path prefix.
# Local dev: http://localhost:5001/api/v1
# Production: https://api.kartriq.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1

# Public site origin used for canonical URLs, sitemap, OpenGraph tags.
# No trailing slash. Used by app/sitemap.ts, app/robots.ts, and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional: analytics & tracking ───────────────────────────────────────────
# These can also be set per-tenant via the admin UI; the public /tracking
# endpoint will override these at runtime if provided.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=

# ── Optional: error monitoring ───────────────────────────────────────────────
# If set, the frontend will initialize Sentry on the client.
NEXT_PUBLIC_SENTRY_DSN=
